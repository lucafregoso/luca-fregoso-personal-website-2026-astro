# ---------------------------------------------------------------------------
# Managed by ai-engineering — rewritten by `ai-eng install`. Do not edit here.
# Ignores transient / per-install / derived artifacts under .ai-engineering/.
# Put project-specific ignore rules in your project-root .gitignore instead.
#
# Committed sources of truth (intentionally NOT ignored): policies/*.rego,
# manifest.yml, specs/*.md, notes/, state/decision-store.json (governance
# decisions + risk acceptances), state/hooks-manifest.json (the hook
# integrity baseline).
# ---------------------------------------------------------------------------

# Per-install state — machine-specific, regenerated by install + governance flows
state/install-state.json
state/ownership-map.json
state/framework-capabilities.json

# Append-only audit + observation streams (per-install)
state/framework-events.ndjson
state/observation-events.ndjson
state/instinct-observations.ndjson

# Instinct extraction watermark — per-session runtime state (spec-162 D-162-02)
observations/meta.json

# Derived database (per-user, rebuilt from the event stream)
state/state.db
state/state.db-wal
state/state.db-shm

# Transient gate / compaction artifacts + lock files
state/gate-findings.json
state/strategic-compact.json
state/locks/

# Runtime working dirs + compiled & signed OPA bundle (bundle.tar.gz lives here)
state/runtime/
runtime/
runs/

# Caches
cache/
.cache/

# Python bytecode — the shipped .ai-engineering/scripts/*.py hooks compile
# __pycache__/*.pyc on every run; never commit it (spec-168).
__pycache__/
*.pyc

# Per-machine local config override
local.yml

# Per-install OPA signing outputs (the bundle they sign is ignored above)
policies/.signatures.json
policies/.manifest

# Secret-material safety net — never let key/credential files slip in
*.pem
*.key
*.p12
*.pfx
credentials*.json

# OS cruft inside the managed tree
.DS_Store
