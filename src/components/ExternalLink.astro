---
interface Props {
  href: string;
  class?: string;
  ariaLabel?: string;
  title?: string;
  showArrow?: boolean;
  newTabLabel?: string;
}

const {
  href,
  class: className = '',
  ariaLabel,
  title,
  showArrow = true,
  newTabLabel = Astro.currentLocale === 'it' ? 'si apre in una nuova scheda' : 'opens in a new tab',
} = Astro.props;

const accessibleLabel = ariaLabel ? `${ariaLabel} (${newTabLabel})` : undefined;
---

<a
  href={href}
  class={className}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={accessibleLabel}
  title={title}
>
  <slot />
  {showArrow && <span class="external-arrow" aria-hidden="true">↗</span>}
  {!ariaLabel && <span class="sr-only"> ({newTabLabel})</span>}
</a>
