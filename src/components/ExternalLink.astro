---
interface Props {
  href: string;
  class?: string;
  ariaLabel?: string;
  title?: string;
  showArrow?: boolean;
}

const {
  href,
  class: className = '',
  ariaLabel,
  title,
  showArrow = true,
} = Astro.props;

const accessibleLabel = ariaLabel ? `${ariaLabel} (opens in a new tab)` : undefined;
---

<a
  href={href}
  class={className}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={accessibleLabel}
  title={title}
>
  <slot />
  {showArrow && <span class="external-arrow" aria-hidden="true">↗</span>}
  {!ariaLabel && <span class="sr-only"> (opens in a new tab)</span>}
</a>
