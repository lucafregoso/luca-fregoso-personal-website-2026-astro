---
import ExternalLink from './ExternalLink.astro';
import { localize, translations, type Locale, type LocalizedText } from '../i18n';
import { archiveHref, type ArchiveType } from '../lib/archive';
import { withBase } from '../lib/url';

type AppearanceFormat = 'video' | 'live-recording' | 'podcast';
type AppearancePlatform = 'youtube' | 'spotify';
type AppearanceRole = 'host' | 'speaker' | 'guest';

interface Appearance {
  title: LocalizedText;
  summary: LocalizedText;
  format: AppearanceFormat;
  platform: AppearancePlatform;
  role: AppearanceRole;
  date: Date;
  duration: string;
  publisher: string;
  platformId: string;
  externalUrl: string;
  lang?: 'en' | 'it';
  poster: string;
  startAtSeconds?: number;
  mobilePresentation: 'stamp' | 'poster' | 'text-only';
}

interface Props {
  appearance: Appearance;
  locale: Locale;
  variant?: 'featured' | 'feed' | 'archive' | 'card';
  anchorId?: string;
}

const { appearance, locale, variant = 'feed', anchorId } = Astro.props;
const t = translations[locale];
const title = localize(appearance.title, locale);
const summary = localize(appearance.summary, locale);
const dateLocale = locale === 'it' ? 'it-IT' : 'en-GB';
const dateLabel = appearance.date.toLocaleDateString(dateLocale, variant === 'archive' || variant === 'card'
  ? { year: 'numeric', month: 'short' }
  : { day: 'numeric', month: 'long', year: 'numeric' });
const Tag = variant === 'feed' ? 'li' : 'article';
const actionLabel = appearance.platform === 'youtube' ? t.appearances.watch : t.appearances.listen;
---

<Tag class:list={[
  'appearance-entry',
  variant === 'featured' && 'featured-story appearance-featured',
  variant === 'feed' && 'feed-item appearance-feed',
  variant === 'archive' && 'writing-item appearance-archive',
  variant === 'card' && 'appearance-card',
]} data-appearance-entry data-format={appearance.format} data-mobile-presentation={appearance.mobilePresentation} id={anchorId}>
  {variant === 'card' ? (
    <>
      <div class="appearance-thumbnail card-thumb" title={`${actionLabel}: ${title}`} aria-hidden="true">
        <img src={withBase(appearance.poster)} alt="" width="1200" height="675" loading="lazy" />
      </div>
      <div class="card-body">
        <div class="appearance-meta mono">
          {/* The poster art already states format and role; the meta line
              only carries what the art can't: publisher (real text, not
              aria-hidden pixels), language marker, date. */}
          <span>{appearance.publisher}{appearance.lang && appearance.lang !== locale ? ` · ${t.appearances.inItalian}` : ''}</span>
          <time datetime={appearance.date.toISOString()}>{dateLabel}</time>
        </div>
        <h3><ExternalLink class="appearance-title-link" href={appearance.externalUrl}>{title}</ExternalLink></h3>
        <p class="card-summary">{summary}</p>
        <ExternalLink class="appearance-action mono" href={appearance.externalUrl}>{actionLabel}</ExternalLink>
      </div>
    </>
  ) : (
    <>
      <div class:list={['appearance-copy', variant === 'feed' && 'feed-body']}>
        <div class:list={['appearance-media', variant === 'archive' && 'appearance-rail']}>
          <div
            class="appearance-thumbnail"
            title={`${actionLabel}: ${title}`}
            aria-hidden="true"
          >
            <img src={withBase(appearance.poster)} alt="" width="1200" height="675" loading="lazy" />
          </div>
          {variant === 'archive' && (
            <div class="appearance-meta mono">
              <span>{appearance.publisher}{appearance.lang && appearance.lang !== locale ? ` · ${t.appearances.inItalian}` : ''}</span>
              <time datetime={appearance.date.toISOString()}>{dateLabel}</time>
            </div>
          )}
        </div>
        <div class="appearance-details">
          <div class="appearance-badges mono" aria-label={locale === 'it' ? 'Tipo di contenuto e ruolo' : 'Content format and role'}>
            <a class="meta-badge meta-badge-neutral" href={archiveHref(locale, appearance.format as ArchiveType)}>{t.appearances.formats[appearance.format]}</a>
            <span class="meta-badge meta-badge-neutral">{t.appearances.roles[appearance.role]}</span>
          </div>
          <h3><ExternalLink class="appearance-title-link" href={appearance.externalUrl}>{title}</ExternalLink></h3>
          <p>{summary}</p>
          <ExternalLink class="appearance-action mono" href={appearance.externalUrl}>{actionLabel}</ExternalLink>
        </div>
      </div>

      {variant !== 'archive' && (
        <div class:list={['appearance-meta', 'mono', variant === 'feed' && 'feed-meta']}>
          <span>{appearance.publisher}{appearance.lang && appearance.lang !== locale ? ` · ${t.appearances.inItalian}` : ''}</span>
          <time datetime={appearance.date.toISOString()}>{dateLabel}</time>
          <span>{appearance.duration}</span>
        </div>
      )}
    </>
  )}
</Tag>

<script>
  document.documentElement.classList.add('js-cards');
  document.addEventListener('click', (event) => {
    if (!(event.target instanceof Element)) return;
    if (event.target.closest('a, button')) return;
    if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || event.button !== 0) return;
    const selection = window.getSelection();
    if (selection && !selection.isCollapsed) return;
    const entry = event.target.closest('[data-appearance-entry]');
    const link = entry?.querySelector('.appearance-title-link') as HTMLAnchorElement | null;
    if (link) link.click();
  });
</script>

<style>
  .appearance-entry { position: relative; }
  .appearance-entry::after {
    content: '';
    position: absolute;
    inset: 1.65rem auto auto -.7rem;
    width: 2px;
    height: 1.75rem;
    border-radius: var(--radius-pill);
    background: var(--lime);
    opacity: 0;
    transform: scaleY(.65);
    transform-origin: top;
    transition: opacity .18s var(--ease-out), transform .18s var(--ease-out);
    pointer-events: none;
  }
  .appearance-entry:hover::after,
  .appearance-entry:focus-within::after { opacity: .8; transform: scaleY(1); }
  .appearance-copy { min-width: 0; display: grid; grid-template-columns: minmax(150px, 25%) minmax(0, 1fr); gap: 1.5rem; align-items: start; }
  .appearance-media { min-width: 0; }
  .appearance-details { min-width: 0; }
  .appearance-details h3 { margin: .55rem 0 0; }
  .appearance-details h3 :global(a) { color: var(--text); }
  .appearance-entry:hover .appearance-details h3 :global(a),
  .appearance-entry:focus-within .appearance-details h3 :global(a) { border-bottom-color: var(--lime); }
  .appearance-details > p { max-width: 66ch; margin: .55rem 0 0; color: var(--text-muted); font-size: var(--text-body-sm); }

  /* ---- Card variant: thumbnail-led, whole card clickable ---- */
  .appearance-card { display: flex; flex-direction: column; align-items: stretch; overflow: hidden; border: 1px solid var(--border); border-radius: var(--radius-md); background: var(--surface); transition: transform .22s var(--ease-out), border-color .22s var(--ease-out), box-shadow .22s var(--ease-out); }
  /* Whole-card click is JS-delegated; only promise a pointer when JS ran. */
  :global(html.js-cards) .appearance-card { cursor: pointer; }
  .appearance-card h3 :global(a) { color: var(--text); }
  .appearance-card:hover h3 :global(a),
  .appearance-card:focus-within h3 :global(a) { border-bottom-color: var(--lime); }
  /* Separator lives in CSS so a wrapped meta line never ends in a dangling
     dot — when the date wraps, the dot travels with it. */
  .appearance-card .appearance-meta time::before { content: '· '; }
  .appearance-card::after { content: none; }
  .appearance-card:hover, .appearance-card:focus-within { transform: translateY(-3px); border-color: color-mix(in srgb, var(--lime), var(--border-strong) 40%); box-shadow: 0 14px 34px color-mix(in srgb, var(--text), transparent 92%); }
  .appearance-card .card-thumb { border: 0; border-radius: 0; border-bottom: 1px solid var(--border); }
  .appearance-card .card-body { flex: 1; display: flex; flex-direction: column; align-items: flex-start; padding: 1.2rem 1.4rem 1.4rem; }
  .appearance-card .appearance-meta { flex-wrap: wrap; }
  .appearance-card h3 { margin: .8rem 0 0; font-size: var(--text-h3); line-height: 1.3; }
  .appearance-card .card-summary { display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; line-clamp: 2; overflow: hidden; max-width: none; margin: .6rem 0 0; color: var(--text-muted); font-size: var(--text-body-sm); }
  .appearance-card :global(.appearance-action) { margin-top: auto; padding-top: .55rem; }
  .appearance-thumbnail { display: block; overflow: hidden; aspect-ratio: 16 / 9; border: 1px solid var(--border); border-radius: 9px; background: var(--surface); cursor: pointer; transition: border-color .18s var(--ease-out); }
  .appearance-thumbnail:hover { border-color: var(--border); border-bottom-color: var(--border); }
  .appearance-thumbnail img { width: 100%; height: 100%; display: block; object-fit: cover; transition: transform .24s var(--ease-out), filter .24s var(--ease-out); }
  .appearance-entry:hover .appearance-thumbnail img,
  .appearance-entry:focus-within .appearance-thumbnail img { transform: scale(1.018); filter: saturate(1.04); }
  :global(.appearance-action) { width: fit-content; min-height: 44px; margin-top: .55rem; display: inline-flex; align-items: center; gap: .35rem; font-size: var(--text-ui); }
  :global(.appearance-action .external-arrow) { display: inline-block; transition: transform .16s var(--ease-out); }
  :global(.appearance-action:hover .external-arrow),
  :global(.appearance-action:focus-visible .external-arrow) { transform: translate(2px, -2px); }
  .appearance-badges { display: flex; flex-wrap: wrap; gap: .4rem; }
  .appearance-meta { display: flex; gap: .45rem; color: var(--text-faint); font-size: var(--text-meta); }
  .appearance-featured { display: grid; grid-template-columns: minmax(0, 1fr) 180px; gap: 2rem; }
  .appearance-featured .appearance-details h3 { max-width: 25ch; font-size: clamp(1.4rem, 2.4vw, 2rem); }
  .appearance-featured .appearance-meta { flex-direction: column; text-align: right; }
  .appearance-feed .appearance-meta { grid-column: 1; grid-row: 1; }
  .appearance-feed .appearance-copy { grid-column: 2; }
  .appearance-archive { padding: 1.6rem 0; border-bottom: 1px solid var(--border); }
  .appearance-archive .appearance-copy { grid-template-columns: clamp(180px, 20vw, 210px) minmax(0, 1fr); gap: 1.75rem; }
  .appearance-rail { min-width: 0; }
  .appearance-rail .appearance-meta { margin-top: .65rem; flex-direction: column; gap: .35rem; text-align: left; }
  @media (max-width: 900px) {
    .appearance-copy { grid-template-columns: minmax(140px, 30%) minmax(0, 1fr); gap: 1.2rem; }
    .appearance-archive .appearance-copy { grid-template-columns: minmax(150px, 28%) minmax(0, 1fr); gap: 1.2rem; }
  }
  @media (max-width: 620px) {
    .appearance-featured { grid-template-columns: 1fr; }
    .appearance-featured .appearance-meta { grid-row: 1; flex-direction: row; text-align: left; }
    .appearance-feed .appearance-meta, .appearance-feed .appearance-copy { grid-column: 1; }
    .appearance-feed .appearance-meta { margin-top: .1rem; flex-direction: row; flex-wrap: wrap; gap: .35rem .65rem; }
    .appearance-feed > .appearance-meta span:last-child { display: none; }
    .appearance-archive .appearance-rail { display: contents; }
    .appearance-archive .appearance-meta { margin-top: 0; grid-column: 1; grid-row: 3; flex-direction: row; flex-wrap: wrap; text-align: left; }
    .appearance-badges { gap: .3rem; }
    .appearance-entry[data-mobile-presentation='stamp'] .appearance-copy,
    .appearance-entry[data-mobile-presentation='poster'] .appearance-copy,
    .appearance-entry[data-mobile-presentation='text-only'] .appearance-copy { grid-template-columns: 1fr; }
    .appearance-entry[data-mobile-presentation='stamp'] .appearance-copy { gap: .85rem; }
    .appearance-entry[data-mobile-presentation='stamp'] .appearance-details { grid-column: 1; grid-row: 1; }
    .appearance-entry[data-mobile-presentation='stamp'] .appearance-media { width: min(8.75rem, 42vw); grid-column: 1; grid-row: 2; }
    .appearance-entry[data-mobile-presentation='stamp'] .appearance-thumbnail { width: min(8.75rem, 42vw); grid-column: 1; grid-row: 2; border-radius: 8px; }
    .appearance-entry[data-mobile-presentation='stamp'] .appearance-meta { grid-column: 1; grid-row: 3; }
    .appearance-entry[data-mobile-presentation='poster'] .appearance-copy { gap: .9rem; }
    .appearance-entry[data-mobile-presentation='poster'] .appearance-media { width: min(100%, 25rem); grid-column: 1; grid-row: 1; }
    .appearance-entry[data-mobile-presentation='poster'] .appearance-thumbnail { width: min(100%, 25rem); max-height: 9.5rem; grid-column: 1; grid-row: 1; border-radius: var(--radius-md); }
    .appearance-entry[data-mobile-presentation='poster'] .appearance-details { grid-column: 1; grid-row: 2; }
    .appearance-entry[data-mobile-presentation='poster'] .appearance-meta { grid-column: 1; grid-row: 3; }
    .appearance-entry[data-mobile-presentation='text-only'] .appearance-thumbnail { display: none; }
    .appearance-entry[data-mobile-presentation='text-only']:not(.appearance-archive) .appearance-media { display: none; }
    .appearance-entry[data-mobile-presentation='text-only'] .appearance-details { grid-row: 1; }
    .appearance-entry[data-mobile-presentation='text-only'] .appearance-meta { grid-column: 1; grid-row: 2; }
    /* Cards stay uniform on phones: full-width thumbnail regardless of the
       stamp/poster presentation hints (text-only may still hide it). */
    .appearance-entry.appearance-card .appearance-thumbnail { width: 100%; max-height: none; border-radius: 0; }
    .appearance-details h3 { font-size: var(--text-body); }
  }
  @media (prefers-reduced-motion: reduce) {
    .appearance-entry::after,
    .appearance-thumbnail,
    .appearance-thumbnail img,
    :global(.appearance-action .external-arrow) { transition: none; }
    .appearance-entry::after { transform: none; }
    .appearance-entry:hover .appearance-thumbnail img,
    .appearance-entry:focus-within .appearance-thumbnail img { transform: none; filter: none; }
    :global(.appearance-action:hover .external-arrow),
    :global(.appearance-action:focus-visible .external-arrow) { transform: none; }
  }
</style>
