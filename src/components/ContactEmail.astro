---
// Obfuscated email. The address never appears as a plain string in the
// HTML source — it's split into data-attributes and reassembled by JS on
// first interaction, so spam harvesters that scrape static HTML get nothing,
// while humans get a normal mailto link.
import { site } from '../data/site';
interface Props { class?: string }
const { class: cls = '' } = Astro.props;
---

<button
  type="button"
  class={`email-reveal ${cls}`}
  data-u={site.emailUser}
  data-d={site.emailDomain}
  aria-label="Reveal email address"
>
  <span class="email-text">email me</span>
</button>

<script is:inline>
  document.querySelectorAll('.email-reveal').forEach(function (btn) {
    let revealed = false;
    function addr() { return btn.getAttribute('data-u') + '@' + btn.getAttribute('data-d'); }
    btn.addEventListener('mouseenter', function () {
      if (!revealed) { btn.querySelector('.email-text').textContent = addr(); revealed = true; }
    });
    btn.addEventListener('click', function () {
      const a = addr();
      btn.querySelector('.email-text').textContent = a;
      revealed = true;
      window.location.href = 'mailto:' + a;
    });
  });
</script>

<style>
  .email-reveal {
    appearance: none; background: none; border: none; padding: 0; margin: 0;
    cursor: pointer; font: inherit; color: var(--accent-text);
    border-bottom: 1px solid transparent;
  }
  .email-reveal:hover { border-bottom-color: var(--lime); }
</style>
