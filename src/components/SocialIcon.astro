---
// Social icons — recognisable brand shapes, drawn in a single consistent
// style: 20×20 viewBox, currentColor, uniform weight. They inherit the
// surrounding text colour so they sit naturally in the mono aesthetic.
interface Props { name: string; class?: string }
const { name, class: cls = '' } = Astro.props;
const n = name.toLowerCase();
