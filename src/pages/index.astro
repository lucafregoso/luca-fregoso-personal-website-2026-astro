---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Media from '../components/Media.astro';
import Lightbox from '../components/Lightbox.astro';
import ContactEmail from '../components/ContactEmail.astro';
import SocialIcon from '../components/SocialIcon.astro';
import ExternalLink from '../components/ExternalLink.astro';
import AppearanceEntry from '../components/AppearanceEntry.astro';
import SectionGlyph from '../components/SectionGlyph.astro';
import { site } from '../data/site';
import { archiveHref, type ArchiveType } from '../lib/archive';
import { withBase } from '../lib/url';
import { localize, translations, type Locale, type LocalizedText } from '../i18n';

interface Props { locale?: Locale }
const locale = Astro.props.locale ?? 'en';
const t = translations[locale];

const allNow = (await getCollection('now')).filter((entry) => entry.data.locales.includes(locale)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const appearances = (await getCollection('appearances'))
  .filter((entry) => entry.data.locales.includes(locale))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latelyAppearances = appearances.filter((entry) => entry.data.placements.includes('lately'));

const timeline = [
  ...allNow.map((entry) => ({ type: 'update' as const, date: entry.data.date, entry })),
  ...latelyAppearances.map((entry) => ({ type: 'appearance' as const, date: entry.data.date, entry })),
].sort((a, b) => b.date.valueOf() - a.date.valueOf());
const todayMs = Date.now();
const upcoming = allNow
  .filter((entry) => entry.data.date.valueOf() > todayMs)
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf())
  .slice(0, 1);
const past = timeline.filter((item) => item.date.valueOf() <= todayMs);
const heroEntry = past[0];
const recentEntries = past.slice(1, 4);
const earlierEntries = past.slice(4);

const talks = (await getCollection('talks')).filter((entry) => entry.data.locales.includes(locale)).sort((a, b) => a.data.order - b.data.order);
const writing = (await getCollection('writing')).filter((entry) => entry.data.locales.includes(locale)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const library = [
  ...writing.map((entry) => ({ type: 'article' as const, date: entry.data.date, entry })),
  ...appearances
    .filter((entry) => entry.data.placements.includes('library'))
    .map((entry) => ({ type: 'appearance' as const, date: entry.data.date, entry })),
].sort((a, b) => b.date.valueOf() - a.date.valueOf());

const appearanceAnchor = (id: string) => `appearance-${id.replace(/[^a-z0-9-]/gi, '-')}`;
const isoDuration = (duration: string) => {
  const parts = duration.split(':').map(Number);
  const [hours, minutes, seconds] = parts.length === 3 ? parts : [0, parts[0], parts[1]];
  return `PT${hours ? `${hours}H` : ''}${minutes ? `${minutes}M` : ''}${seconds ? `${seconds}S` : ''}`;
};
const appearanceStructuredData = appearances
  .filter((entry) => entry.data.placements.includes('library'))
  .map((entry) => {
    const url = new URL(`${Astro.url.pathname}#${appearanceAnchor(entry.id)}`, Astro.site).toString();
    const common = {
      '@context': 'https://schema.org',
      '@id': url,
      name: localize(entry.data.title, locale),
      description: localize(entry.data.summary, locale),
      datePublished: entry.data.date.toISOString().slice(0, 10),
      duration: isoDuration(entry.data.duration),
      url: entry.data.externalUrl,
      mainEntityOfPage: url,
      thumbnailUrl: new URL(withBase(entry.data.poster), Astro.site).toString(),
      publisher: { '@type': 'Organization', name: entry.data.publisher },
      contributor: {
        '@type': 'Person',
        '@id': new URL(withBase('/#person'), Astro.site).toString(),
        name: site.name,
      },
    };
    return entry.data.format === 'podcast'
      ? { ...common, '@type': 'PodcastEpisode', associatedMedia: { '@type': 'AudioObject', contentUrl: entry.data.externalUrl } }
      : { ...common, '@type': 'VideoObject', contentUrl: entry.data.externalUrl, uploadDate: entry.data.date.toISOString() };
  });

const monthYear = (date: Date) =>
  date.toLocaleDateString(locale === 'it' ? 'it-IT' : 'en-GB', { year: 'numeric', month: 'short' });
const dayMonth = (date: Date) =>
  date.toLocaleDateString(locale === 'it' ? 'it-IT' : 'en-GB', { day: '2-digit', month: 'short' });
const fullDate = (date: Date) =>
  date.toLocaleDateString(locale === 'it' ? 'it-IT' : 'en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

const kindLabel: Record<string, string> = t.lately.kinds;
const kindArchiveHref = (type: string) => archiveHref(locale, type as ArchiveType);

function outlink(entry: { url?: string; urlLabel?: LocalizedText; urlStyle?: string }) {
  if (!entry.url) return null;
  let host = '';
  try { host = new URL(entry.url).hostname.replace(/^www\./, ''); } catch {}
  const platform = host.includes('linkedin') ? 'LinkedIn' : host;
  return {
    href: entry.url,
    label:
      (entry.urlLabel ? localize(entry.urlLabel, locale) : undefined) ??
      (entry.urlStyle === 'strong' ? t.lately.readFull(platform) : t.lately.read(platform)),
    strong: entry.urlStyle === 'strong',
  };
}

function caseHref(href: string) {
  return href.startsWith('/') ? withBase(href) : href;
}
---

<BaseLayout locale={locale} title={t.meta.title} description={t.meta.description} structuredData={appearanceStructuredData}>
  <SiteHeader
    locale={locale}
    navItems={[
      { href: '#work', label: t.nav.work },
      { href: '#lately', label: t.nav.lately },
      { href: '#talks', label: t.nav.talks },
      { href: '#media', label: t.nav.writing },
      { href: '#contact', label: t.nav.contact },
    ]}
  />
  <div class="site-shell">
    <main id="main" tabindex="-1">
      <section class="hero" id="top" aria-labelledby="hero-title">
        <div class="hero-copy">
          <p class="eyebrow mono"><span class="status-dot" aria-hidden="true"></span>{t.hero.eyebrow}</p>
          <h1 id="hero-title">{t.hero.headline}</h1>
          <p class="hero-intro">{t.hero.intro}</p>
          <p class="hero-proof">{t.hero.proof}</p>
          <div class="hero-actions">
            <a class="button button-primary" href="#contact">{t.hero.primary}</a>
            <a class="button button-secondary" href="#work">{t.hero.secondary}</a>
          </div>
          <div class="utility-links mono" aria-label={t.hero.profileLinks}>
            <ExternalLink href={site.links.linkedin}>LinkedIn</ExternalLink>
            <ExternalLink href={site.links.sessionize}>Sessionize</ExternalLink>
            <a href={withBase('/cv.pdf')}>{t.hero.cv}</a>
          </div>
        </div>

        <figure class="hero-visual">
          <img
            src={withBase('/hackathon-2026.jpg')}
            alt={t.hero.imageAlt}
            width="1200"
            height="900"
          />
          <figcaption class="mono">
            <span>{t.hero.imageContext}</span>
            <span>{t.hero.imagePlace}</span>
          </figcaption>
        </figure>
      </section>

      <section class="metrics" aria-label={locale === 'it' ? 'Impatto in numeri' : 'Impact in numbers'}>
        {t.metrics.map((metric) => (
          <div class="metric">
            <strong>{metric.value}</strong>
            <span>{metric.label}</span>
          </div>
        ))}
      </section>

      <section class="section work" id="work" aria-labelledby="work-title">
        <div class="section-heading">
          <p class="section-number mono"><SectionGlyph name="work" />{t.work.number}</p>
          <h2 id="work-title">{t.work.title}</h2>
          <p>{t.work.intro}</p>
        </div>

        <div class="capability-grid">
          {t.capabilities.map((capability) => (
            <article class="capability">
              <span class="capability-number mono">{capability.number}</span>
              <h3>{capability.title}</h3>
              <p>{capability.description}</p>
            </article>
          ))}
        </div>

        <div class="case-grid">
          {t.caseStudies.map((caseStudy) => (
            <article class="case-card">
              <p class="case-label mono">{caseStudy.label}</p>
              <h3>{caseStudy.title}</h3>
              <p>{caseStudy.description}</p>
              <strong class="case-outcome">{caseStudy.outcome}</strong>
              <a
                href={caseHref(caseStudy.href)}
                {...(caseStudy.download ? { 'aria-label': `${caseStudy.linkLabel}, PDF` } : {})}
              >
                {caseStudy.linkLabel} <span aria-hidden="true">→</span>
              </a>
            </article>
          ))}
        </div>
      </section>

      <section class="section stream tinted" id="lately" aria-labelledby="lately-title">
        <div class="section-heading compact">
          <p class="section-number mono"><SectionGlyph name="lately" />{t.lately.number}</p>
          <div class="heading-row">
            <h2 id="lately-title">{t.lately.title}</h2>
            {heroEntry && <span class="updated mono">{t.lately.updated} {dayMonth(heroEntry.date)}</span>}
          </div>
          <p>{t.lately.intro}</p>
        </div>

        {upcoming.length > 0 && (
          <ul class="upcoming">
            {upcoming.map((entry) => (
              <li>
                <span class="up-tag meta-badge meta-badge-status mono">{t.lately.upcoming}</span>
                <span class="up-title">{localize(entry.data.title, locale)}</span>
                {entry.data.location && <span class="up-location mono">{localize(entry.data.location, locale)}</span>}
                <time class="up-date mono" datetime={entry.data.date.toISOString()}>{dayMonth(entry.data.date)}</time>
              </li>
            ))}
          </ul>
        )}

        {heroEntry?.type === 'update' && (
          <article data-reveal class={`featured-story media-presentation-${heroEntry.entry.data.mediaPresentation} ${heroEntry.entry.data.featured ? 'is-featured' : ''}`}>
            <div class="story-content">
              <div class="story-meta mono">
                <a class="meta-badge meta-badge-neutral" href={kindArchiveHref(heroEntry.entry.data.kind)}>{kindLabel[heroEntry.entry.data.kind] ?? heroEntry.entry.data.kind}</a>
                <time datetime={heroEntry.date.toISOString()}>{fullDate(heroEntry.date)}</time>
              </div>
              <h3>{localize(heroEntry.entry.data.title, locale)}</h3>
              {heroEntry.entry.data.location && <p class="story-location mono">{localize(heroEntry.entry.data.location, locale)}</p>}
              {heroEntry.entry.data.blurb && <p class="story-copy">{localize(heroEntry.entry.data.blurb, locale)}</p>}
              {outlink(heroEntry.entry.data) && (
                <ExternalLink class={`outlink mono ${outlink(heroEntry.entry.data)!.strong ? 'is-strong' : ''}`} href={outlink(heroEntry.entry.data)!.href}>
                  {outlink(heroEntry.entry.data)!.label}
                </ExternalLink>
              )}
            </div>
            <Media locale={locale} media={heroEntry.entry.data.media} presentation={heroEntry.entry.data.mediaPresentation} galleryId={`g-${heroEntry.entry.id}`} />
          </article>
        )}
        {heroEntry?.type === 'appearance' && <AppearanceEntry appearance={heroEntry.entry.data} {locale} variant="featured" />}

        <ol class="feed">
          {recentEntries.map((item) => item.type === 'update' ? (
            <li data-reveal class={`feed-item ${item.entry.data.featured ? 'is-featured' : ''}`}>
              <div class="feed-meta mono">
                <time datetime={item.date.toISOString()}>{dayMonth(item.date)}</time>
                <a class="meta-badge meta-badge-neutral" href={kindArchiveHref(item.entry.data.kind)}>{kindLabel[item.entry.data.kind] ?? item.entry.data.kind}</a>
              </div>
              <div class={`feed-body media-presentation-${item.entry.data.mediaPresentation}`}>
                <div class="feed-copy">
                  <h3>{localize(item.entry.data.title, locale)}</h3>
                  {item.entry.data.location && <p class="feed-location mono">{localize(item.entry.data.location, locale)}</p>}
                  {item.entry.data.blurb && <p>{localize(item.entry.data.blurb, locale)}</p>}
                  {outlink(item.entry.data) && (
                    <ExternalLink class={`outlink mono ${outlink(item.entry.data)!.strong ? 'is-strong' : ''}`} href={outlink(item.entry.data)!.href}>
                      {outlink(item.entry.data)!.label}
                    </ExternalLink>
                  )}
                </div>
                <Media locale={locale} media={item.entry.data.media} presentation={item.entry.data.mediaPresentation} galleryId={`g-${item.entry.id}`} />
              </div>
            </li>
          ) : <AppearanceEntry appearance={item.entry.data} {locale} variant="feed" />)}
        </ol>

        {earlierEntries.length > 0 && (
          <div class="earlier">
            <a class="archive-cta mono" href={archiveHref(locale)}>{t.lately.archiveCta}</a>
          </div>
        )}
      </section>

      <section class="section" id="talks" aria-labelledby="talks-title">
        <div class="section-heading compact">
          <p class="section-number mono"><SectionGlyph name="talks" />{t.talks.number}</p>
          <h2 id="talks-title">{t.talks.title}</h2>
          <p>{t.talks.intro}</p>
        </div>
        <div class="talk-grid">
          {talks.map((talk) => (
            <article class="talk-card">
              <span class="talk-status meta-badge meta-badge-neutral mono">{t.talks.status}</span>
              <h3>{localize(talk.data.title, locale)}</h3>
              <p>{localize(talk.data.abstract, locale)}</p>
              <p class="talk-events mono">{talk.data.events.join(' · ')}</p>
              {talk.data.sessionizeUrl && (
                <ExternalLink href={talk.data.sessionizeUrl}>{t.talks.view}</ExternalLink>
              )}
            </article>
          ))}
        </div>
        <ExternalLink class="section-link mono" href={site.links.sessionize}>{t.talks.fullProfile}</ExternalLink>
      </section>

      <section class="section writing tinted" id="media" aria-labelledby="writing-title">
        <div class="section-heading compact">
          <p class="section-number mono"><SectionGlyph name="media" />{t.writing.number}</p>
          <h2 id="writing-title">{t.writing.title}</h2>
          <p>{t.writing.intro}</p>
        </div>
        <div class="writing-list">
          {library.map((item) => item.type === 'article' ? (
            <article class="writing-item">
              <div class="writing-rail">
                <div class="writing-meta mono">
                  <span>{item.entry.data.publication}</span>
                  <time datetime={item.entry.data.date.toISOString()}>{monthYear(item.entry.data.date)}</time>
                </div>
              </div>
              <div class="writing-body">
                <div class="archive-badges mono"><a class="meta-badge meta-badge-neutral" href={archiveHref(locale, 'article')}>{t.writing.article}</a></div>
                <h3><ExternalLink href={item.entry.data.url}>{localize(item.entry.data.title, locale)}</ExternalLink></h3>
                <p>{localize(item.entry.data.summary, locale)}</p>
              </div>
            </article>
          ) : <AppearanceEntry appearance={item.entry.data} {locale} variant="archive" anchorId={appearanceAnchor(item.entry.id)} />)}
        </div>
      </section>
    </main>

    <footer class="contact" id="contact">
      <p class="section-number mono"><SectionGlyph name="contact" />{t.contact.number}</p>
      <div class="contact-grid">
        <div>
          <h2>{t.contact.title}</h2>
          <p>{t.contact.intro}</p>
        </div>
        <div class="contact-actions">
          <ContactEmail locale={locale} />
          <ExternalLink class="button button-secondary" href={site.links.linkedin}>{t.contact.linkedin}</ExternalLink>
          <a class="text-link mono" href={withBase('/cv.pdf')}>{t.contact.cv}</a>
          <nav class="social-links" aria-label={t.contact.socials}>
            {site.socials.map((social) => (
              <ExternalLink href={social.url} ariaLabel={social.name} title={social.name} showArrow={false}>
                <SocialIcon name={social.name} class="social-icon" />
              </ExternalLink>
            ))}
          </nav>
        </div>
      </div>
      <p class="colophon mono">{t.contact.colophon}</p>
    </footer>
  </div>

  <Lightbox locale={locale} />
</BaseLayout>

<style>
  .site-shell { width: min(calc(100% - 3rem), var(--shell)); margin: 0 auto; }
  :is(#top, #work, #lately, #talks, #media, #contact) { scroll-margin-top: 5.5rem; }

  .hero { min-height: min(760px, calc(100svh - 76px)); padding: 5rem 0 6rem; display: grid; grid-template-columns: minmax(0, 7fr) minmax(280px, 5fr); align-items: center; gap: clamp(3rem, 8vw, 7rem); }
  .eyebrow, .section-number { margin: 0 0 1.25rem; color: var(--accent-text); font-size: .72rem; letter-spacing: .08em; text-transform: uppercase; }
  .status-dot { width: 8px; height: 8px; display: inline-block; margin-right: .65rem; border-radius: 50%; background: var(--lime); box-shadow: 0 0 0 5px color-mix(in srgb, var(--lime), transparent 78%); }
  .hero h1 { margin: 0; max-width: 12ch; font-size: clamp(3rem, 6.5vw, 5.7rem); line-height: .98; letter-spacing: -.065em; text-wrap: balance; }
  .hero-intro { max-width: 58ch; margin: 2rem 0 0; font-size: clamp(1.15rem, 2vw, 1.42rem); line-height: 1.5; }
  .hero-proof { max-width: 62ch; margin: 1rem 0 0; color: var(--text-muted); }
  .hero-actions, .utility-links { display: flex; flex-wrap: wrap; align-items: center; gap: .75rem; }
  .hero-actions { margin-top: 2rem; }
  .utility-links { margin-top: 1.25rem; gap: 1.4rem; }
  .utility-links :global(a) { min-height: 44px; display: inline-flex; align-items: center; font-size: .76rem; }
  .button { min-height: 48px; padding: .7rem 1.15rem; border: 1px solid var(--border-strong); border-radius: var(--radius-md); display: inline-flex; justify-content: center; align-items: center; font: 650 .86rem/1.2 var(--font-mono); text-align: center; cursor: pointer; transition: transform .18s var(--ease-out), border-color .18s, background .18s; }
  .button:hover { transform: translateY(-2px); border-color: var(--lime); }
  .button-primary { color: #171715; background: var(--lime); border-color: var(--lime); }
  .button-primary:hover { color: #171715; background: var(--lime-dim); }
  .button-secondary { color: var(--text); background: var(--surface); }
  .hero-visual { position: relative; margin: 0; align-self: stretch; min-height: 460px; overflow: hidden; border-radius: var(--radius-md); background: var(--surface-2); }
  .hero-visual::after { content: ''; position: absolute; inset: 0; box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--text), transparent 84%); border-radius: inherit; pointer-events: none; }
  .hero-visual img { width: 100%; height: 100%; display: block; object-fit: cover; filter: saturate(.82) contrast(1.05); transition: transform .5s var(--ease-out); }
  .hero-visual:hover img { transform: scale(1.015); }
  .hero-visual figcaption { position: absolute; z-index: 1; left: 1rem; right: 1rem; bottom: 1rem; padding: .65rem .8rem; display: flex; justify-content: space-between; gap: 1rem; border-radius: var(--radius-sm); color: #fff; background: rgba(10, 12, 16, .78); backdrop-filter: blur(8px); font-size: .65rem; text-transform: uppercase; letter-spacing: .07em; }

  .metrics { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); border-block: 1px solid var(--border); }
  .metric { min-height: 136px; padding: 1.4rem 1rem; display: flex; flex-direction: column; justify-content: center; border-top: 1px solid var(--border); border-right: 1px solid var(--border); }
  .metric:nth-child(-n + 3) { border-top: 0; }
  .metric:nth-child(3n) { border-right: 0; }
  .metric strong { font-size: clamp(1.5rem, 3vw, 2.15rem); letter-spacing: -.04em; }
  .metric span { margin-top: .35rem; color: var(--text-muted); font-size: .76rem; line-height: 1.45; }

  .section { padding: 7rem 0; position: relative; }
  .section-heading { display: grid; grid-template-columns: 1fr 2fr; column-gap: 3rem; margin-bottom: 3.5rem; }
  .section-heading .section-number { grid-row: 1 / span 2; }
  .section-number { display: flex; align-items: center; gap: .8rem; color: var(--accent-text); }
  .section-number :global(.section-glyph) { flex: none; width: 2rem; height: 2rem; }
  .section-heading h2 { max-width: 15ch; margin: 0; font-size: clamp(2.2rem, 4.5vw, 4rem); line-height: 1.05; letter-spacing: -.05em; text-wrap: balance; }
  .section-heading > p:last-child { max-width: 60ch; margin: 1.2rem 0 0; color: var(--text-muted); }
  .section-heading.compact { margin-bottom: 2.5rem; }
  .heading-row { display: flex; align-items: baseline; justify-content: space-between; gap: 2rem; }
  .updated { flex: none; color: var(--text-faint); font-size: .68rem; text-transform: uppercase; letter-spacing: .06em; }
  .tinted { isolation: isolate; }
  .tinted::before { content: ''; position: absolute; z-index: 0; inset: 0 50%; width: 100vw; transform: translateX(-50%); background: var(--surface-2); }
  .tinted > * { position: relative; z-index: 1; }
  .stream { border-top: 0; }

  .capability-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; overflow: hidden; border: 1px solid var(--border); border-radius: var(--radius-md); background: var(--border); }
  .capability { min-height: 260px; padding: 1.6rem; background: var(--surface); }
  .capability-number { color: var(--accent-text); font-size: .7rem; }
  .capability h3 { margin: 3.5rem 0 .8rem; font-size: 1.25rem; }
  .capability p { margin: 0; color: var(--text-muted); font-size: .9rem; }
  .case-grid { margin-top: 4rem; display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem; }
  .case-card { min-height: 390px; padding: 1.6rem; display: flex; flex-direction: column; border-top: 3px solid var(--lime); background: var(--surface-2); border-radius: 0 0 var(--radius-md) var(--radius-md); }
  .case-label { margin: 0 0 3rem; color: var(--accent-text); font-size: .66rem; text-transform: uppercase; letter-spacing: .08em; }
  .case-card h3 { margin: 0 0 1rem; font-size: 1.35rem; }
  .case-card > p:not(.case-label) { margin: 0; color: var(--text-muted); font-size: .9rem; }
  .case-outcome { margin-top: auto; padding: 1.5rem 0 1rem; font-size: .88rem; line-height: 1.45; }
  .case-card a { width: fit-content; font: 600 .78rem/1.4 var(--font-mono); }

  .upcoming { margin: 0 0 2rem; padding: 0; list-style: none; }
  .upcoming li { min-height: 68px; display: grid; grid-template-columns: auto 1fr auto auto; align-items: center; gap: 1rem; padding: .8rem 1rem; border: 1px solid color-mix(in srgb, var(--lime), var(--border) 62%); border-radius: var(--radius-md); background: var(--surface-accent); box-shadow: 0 12px 34px color-mix(in srgb, var(--text), transparent 94%); }
  .up-title { font-weight: 650; }
  .up-location, .up-date { color: var(--text-faint); font-size: .7rem; }
  .featured-story { padding: 2.5rem 0 3rem; border-bottom: 1px solid var(--border); }
  .featured-story.is-featured { padding-left: 1.25rem; border-left: 3px solid var(--lime); }
  .story-meta { display: flex; gap: 1rem; color: var(--text-faint); font-size: .68rem; text-transform: uppercase; letter-spacing: .07em; }
  .featured-story h3 { max-width: 25ch; margin: .8rem 0 0; font-size: clamp(1.7rem, 3vw, 2.6rem); }
  .story-location, .feed-location { margin: .5rem 0 0; color: var(--text-faint); font-size: .72rem; }
  .story-copy { max-width: 68ch; font-size: 1.05rem; }
